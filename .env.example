# Amazon Product Advertising API (PA-API 5.0) — optional.
# Leave these blank to have the Amazon provider report "Not Connected"
# without affecting any other part of the app. Requires an Amazon
# Associates account with qualifying sales.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE=www.amazon.com

# Mercado Libre — OAuth 2.0 Authorization Code flow. As of Mercado Libre's
# 2023 API changes, /sites/{site}/search requires a user-authorized access
# token even for public results; Mercado Libre does NOT support the
# client_credentials grant for this API. Register a free app at
# https://developers.mercadolibre.com (no sales requirement) to get
# ML_CLIENT_ID/ML_CLIENT_SECRET, then set ML_REDIRECT_URI to this app's
# callback URL and register that SAME url on the Mercado Libre app (must
# match exactly). Leave any of these blank to have the Mercado Libre
# provider report "Not Connected" without affecting any other part of the
# app. Once configured, connect an account from the status bar in the UI,
# or by visiting /api/marketplace/mercadolibre/connect.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:3000/api/marketplace/mercadolibre/callback

# Country-specific authorization domain — must match the country the ML
# app above was registered in (e.g. https://auth.mercadolibre.com.mx,
# https://auth.mercadolibre.com.br). Defaults to Argentina if unset.
ML_AUTH_DOMAIN=https://auth.mercadolibre.com.ar

# The default Mercado Libre country (used until a user picks one in the
# app) is Mexico (MLM); see src/lib/marketplace/countries.ts for the full
# list of supported countries.
