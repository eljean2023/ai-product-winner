# Marketplace data comes entirely from official marketplace APIs — no
# SerpAPI dependency in the active runtime flow (see
# src/lib/marketplace/registry.ts). Every provider below is independent:
# leave any of them blank to have that provider report "Not Connected"
# without affecting any other part of the app.

# Amazon Product Advertising API (PA-API 5.0). Requires an Amazon Associates
# account with qualifying sales.
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=
AMAZON_HOST=webservices.amazon.com
AMAZON_REGION=us-east-1
AMAZON_MARKETPLACE=www.amazon.com

# Mercado Libre — LatAm provider, OAuth 2.0 Authorization Code flow. As of
# Mercado Libre's 2023 API changes, /sites/{site}/search requires a
# user-authorized access token even for public results; Mercado Libre does
# NOT support the client_credentials grant for this API. This OAuth
# connection is a one-time, single-tenant setup step for whoever deploys
# this app — it is never shown to, or required from, ordinary visitors.
# Register a free app at https://developers.mercadolibre.com (no sales
# requirement) to get ML_CLIENT_ID/ML_CLIENT_SECRET, then set
# ML_REDIRECT_URI to this app's callback URL and register that SAME url on
# the Mercado Libre app (must match exactly). Once configured, the deployer
# connects an account once by visiting
# /api/marketplace/mercadolibre/connect.
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REDIRECT_URI=http://localhost:3000/api/marketplace/mercadolibre/callback

# Country-specific authorization domain — must match the country the ML
# app above was registered in (e.g. https://auth.mercadolibre.com.mx,
# https://auth.mercadolibre.com.br). Defaults to Argentina if unset.
ML_AUTH_DOMAIN=https://auth.mercadolibre.com.ar

# The default Mercado Libre country (used until a user picks one in the
# app) is Mexico (MLM); see src/lib/marketplace/countries.ts for the full
# list of supported countries.

# eBay Browse API. Uses an application-only OAuth token (client credentials
# grant), so no seller login or redirect flow is required — just an eBay
# developer account at https://developer.ebay.com.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# Walmart Affiliate API v2. Requires an approved Impact.com
# affiliate/publisher account for Walmart (https://walmart.io) and an
# RSA key pair generated for it; the public key is uploaded to the
# Walmart I/O dashboard, the private key stays here.
WALMART_CONSUMER_ID=
# PEM-encoded RSA private key. Since env files can't hold real newlines,
# write it with literal \n sequences, e.g.:
# WALMART_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIExampleKey...\n-----END RSA PRIVATE KEY-----"
WALMART_PRIVATE_KEY=
WALMART_KEY_VERSION=1
WALMART_PUBLISHER_ID=

# Keepa — historical intelligence provider (price history, sales rank) for
# an already-known Amazon ASIN. Not a search provider — never registered in
# registry.ts, never contributes to a marketplace search; used only to
# enrich a listing the app already found via Amazon. Get a key at
# https://keepa.com/#!api.
KEEPA_API_KEY=
# Keepa's numeric domain id — 1=com (US, default), 2=co.uk, 3=de, 4=fr,
# 5=co.jp, 6=ca, 8=it, 9=es, 10=in, 11=com.mx.
KEEPA_DOMAIN=1

# --- Disabled — not part of the active runtime flow ---
#
# SerpAPI is fully implemented (src/lib/marketplace/providers/serpapi) but
# is intentionally NOT registered in src/lib/marketplace/registry.ts. No
# SerpAPI request is ever made by this app, whether or not the key below is
# set — it exists only as a possible future fallback that a deliberate code
# change would need to re-enable. Setting SERPAPI_API_KEY does nothing on
# its own.
SERPAPI_API_KEY=
SERPAPI_AMAZON_DOMAIN=amazon.com
SERPAPI_AMAZON_CURRENCY=USD
SERPAPI_EBAY_CURRENCY=USD
